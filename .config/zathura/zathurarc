# Gruvbox colorcheme

set sandbox none
map p print

set notification-error-bg       "#1d2021" # Red
set notification-error-fg       "#cc241d" # Foreground
set notification-warning-bg     "#1d2021" # Orange
set notification-warning-fg     "#cc241d" # Selection
set notification-bg             "#1d2021" # Background
set notification-fg             "#fe8019" # Foreground

set completion-bg               "#1d2021" # Background
set completion-fg               "#fbf1c7" # Comment
set completion-group-bg         "#1d2021" # Background
set completion-group-fg         "#d3869b" # Comment
set completion-highlight-bg     "#282828" # Selection
set completion-highlight-fg     "#fbf1c7" # Foreground

set index-bg                    "#3c3836" # Background
set index-fg                    "#98971a" # Foreground
set index-active-bg             "#3c3836" # Current Line
set index-active-fg             "#fbf1c7" # Foreground

set inputbar-bg                 "#1d2021" # Background
set inputbar-fg                 "#fbf1c7" # Foreground

set statusbar-bg                "#282828" # Background
set statusbar-fg                "#fbf1c7" # Foreground

set highlight-color             "#fe8019" # Orange
set highlight-active-color      "#98971a" # Pink

set default-bg                  "#1d2021" # Background
set default-fg                  "#fbf1c7" # Foreground

# set render-loading              true
#set render-loading-fg           "#282a36" # Background
#set render-loading-bg           "#fbf1c7" # Foreground

# Recolor mode settings
set recolor                     true
set recolor-lightcolor          "#1d2021" # Background
set recolor-darkcolor           "#fbf1c7" # Foreground
set recolor-keephue             true
