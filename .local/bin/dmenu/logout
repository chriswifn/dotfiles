#!/bin/sh

# A simple dmenu script to (will not work if used with another init system than systemd):
# - Lock screen (slock from suckless)
# - Logout (will kill all instances of X currently running)
# - Reboot: (self explanatory)
# - Shutdown: (self explanatory)
# - Suspend: (self explanatory)
# Don't use this if you are not sure about what you are doing. As soon as you choose 
# an option it will execute the option

pgrep -x dmenu && exit
CHOICE=$(printf "Lock\nLogout\nReboot\nShutdown\nSuspend\nQuit" | dmenu -i -p "Choose option:") &&
    case "$CHOICE" in
        "Lock")
            slock ;;
        "Logout")
            pkill -15 Xorg;;
        "Reboot")
            systemctl reboot ;;
        "Shutdown")
            systemctl poweroff ;;
        "Suspend")
            systemctl suspend ;;
        "Quit")
            exit ;;
    esac
