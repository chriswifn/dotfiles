# Doom-One Colorscheme

set sandbox none
map p print

set notification-error-bg       "#131a1c" # Red
set notification-error-fg       "#e74c4c" # Foreground
set notification-warning-bg     "#131a1c" # Orange
set notification-warning-fg     "#e74c4c" # Selection
set notification-bg             "#131a1c" # Background
set notification-fg             "#e7ac7e" # Foreground

set completion-bg               "#131a1c" # Background
set completion-fg               "#d6d6d6" # Comment
set completion-group-bg         "#131a1c" # Background
set completion-group-fg         "#ef7cbb" # Comment
set completion-highlight-bg     "#5b98a9" # Selection
set completion-highlight-fg     "#d6d6d6" # Foreground

set index-bg                    "#131a1c" # Background
set index-fg                    "#5b98a9" # Foreground
set index-active-bg             "#131a1c" # Current Line
set index-active-fg             "#d6d6d6" # Foreground

set inputbar-bg                 "#131a1c" # Background
set inputbar-fg                 "#d6d6d6" # Foreground

set statusbar-bg                "#131a1c" # Background
set statusbar-fg                "#d6d6d6" # Foreground

set highlight-color             "#e7ac7e" # Orange
set highlight-active-color      "#5699af" # Pink

set default-bg                  "#131a1c" # Background
set default-fg                  "#d6d6d6" # Foreground

# set render-loading              true
#set render-loading-fg           "#282a36" # Background
#set render-loading-bg           "#f8f8f2" # Foreground

# Recolor mode settings
set recolor                     true
set recolor-lightcolor          "#131a1c" # Background
set recolor-darkcolor           "#d6d6d6" # Foreground
set recolor-keephue             true

