#!/bin/sh

if grep -xq 'up' /sys/class/net/wl*/operstate 2>/dev/null ; then
  wifiicon="^c#198844^WIFI^d^"
elif grep -xq 'down' /sys/class/net/wl*/operstate 2>/dev/null ; then
	grep -xq '0x1003' /sys/class/net/wl*/flags && wifiicon="^c#fba922^DOWN^d^" || wifiicon="^c#cc342b^N/A^d^"
fi

[ -d /sys/class/net/wg-* ] && vpnicon="^c#198844^VPN^d^" || vpnicon="^c#cc342b^N/A^d^"
[ -d /sys/class/net/ppp* ] && uniicon="^c#cc342b^UNI^d^" || uniicon="^c#198844^N/A^d^"

#printf "%s %s %s %s\n" "$wifiicon" "$(sed "s/down/down/;s/up/eth/" /sys/class/net/enp2*/operstate 2>/dev/null)" "$(sed "s/.*/vpn/" /sys/class/net/wg-*/operstate 2>/dev/null)" "$(sed "s/.*/uni/" /sys/class/net/ppp*/operstate 2>/dev/null)" 

printf "%s %s%s %s\n" "$wifiicon" "$(sed "s/down//;s/up/^c#198844^ETH^d^/" /sys/class/net/e*/operstate 2>/dev/null | tr '\n' '')" "$vpnicon" "$uniicon"

# printf "%s %s %s\n" "$wifiicon" "$vpnicon" "$uniicon"
