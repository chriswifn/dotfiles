# Doom-One Colorscheme

set sandbox none
map p print

set notification-error-bg       "#1d1f21" # Red
set notification-error-fg       "#cc342b" # Foreground
set notification-warning-bg     "#1d1f21" # Orange
set notification-warning-fg     "#cc342b" # Selection
set notification-bg             "#1d1f21" # Background
set notification-fg             "#fba922" # Foreground

set completion-bg               "#1d1f21" # Background
set completion-fg               "#c5c8c6" # Comment
set completion-group-bg         "#1d1f21" # Background
set completion-group-fg         "#a36ac7" # Comment
set completion-highlight-bg     "#3971ed" # Selection
set completion-highlight-fg     "#c5c8c6" # Foreground

set index-bg                    "#1d1f21" # Background
set index-fg                    "#3971ed" # Foreground
set index-active-bg             "#1d1f21" # Current Line
set index-active-fg             "#c5c8c6" # Foreground

set inputbar-bg                 "#1d1f21" # Background
set inputbar-fg                 "#c5c8c6" # Foreground

set statusbar-bg                "#1d1f21" # Background
set statusbar-fg                "#c5c8c6" # Foreground

set highlight-color             "#fba922" # Orange
set highlight-active-color      "#5699af" # Pink

set default-bg                  "#1d1f21" # Background
set default-fg                  "#c5c8c6" # Foreground

# set render-loading              true
#set render-loading-fg           "#282a36" # Background
#set render-loading-bg           "#f8f8f2" # Foreground

# Recolor mode settings
set recolor                     true
set recolor-lightcolor          "#1d1f21" # Background
set recolor-darkcolor           "#c5c8c6" # Foreground
set recolor-keephue             true

