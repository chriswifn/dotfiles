#!/bin/sh

if grep -xq 'up' /sys/class/net/wl*/operstate 2>/dev/null ; then
  wifiicon="w"
elif grep -xq 'down' /sys/class/net/wl*/operstate 2>/dev/null ; then
	grep -xq '0x1003' /sys/class/net/wl*/flags && wifiicon="-" || wifiicon="n/a"
fi

vpnicon="-" && [ "$(ls /sys/class/net/wg*/ 2>/dev/null)" ] && vpnicon="v"
uniicon="-" && [ "$(ls /sys/class/net/ppp*/ 2>/dev/null)" ] && uniicon="u"

printf "[%s %s %s\n" "$wifiicon" "$vpnicon" "$uniicon"

