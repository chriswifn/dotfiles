#!/bin/sh

# Dmenu script to control network connection including vpns

on() {
	nmcli connection up "$1"
}

off() {
	nmcli connection down "$1"
}

OPTION=$(printf "wifi\nvpn\nwireguard\nethernet" | dmenu -i -p "Select type:") || exit 0

NAMES=$(nmcli connection | grep "$OPTION" | awk -F '  ' '{ print $1 }')  
CHOICE=$(echo "$NAMES" | dmenu -i -p "Select name:")  || exit 0
CHOICE2=$(printf "on\noff" | dmenu -i -p "Select (dis)connect:") || exit 0
case "$CHOICE2" in
	"on") 
		on "$CHOICE" #&& pkill -RTMIN+11 dwmblocks
		exit
		;;
	"off")
		off "$CHOICE" #&& pkill -RTMIN+11 dwmblocks
    exit
		;;
	*) 
		exit
		;;
esac
