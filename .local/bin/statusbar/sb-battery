#!/bin/sh

capacity="$(cat /sys/class/power_supply/BAT0/capacity 2>/dev/null)"
if [ "$capacity" -ge "66" ]; then
  color="#198844"
else
  [ "$capacity" -ge "33" ] && color="#fba922" || color="#cc342b"
fi

to25=$((capacity / 4))
x=$((29 - to25))
printf "%s\n" "^r0,7,2,6^^r2,5,29,10^^c#121f21^^r3,6,27,8^^c$color^^r$x,7,$to25,6^^d^^f31^"

