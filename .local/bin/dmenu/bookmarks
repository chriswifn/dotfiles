#!/bin/sh

# A script for bookmarks (because nobody wants to have their bookmarks in the browser)

# this script assumes to following structure in the bookmarks.txt file:
# <identifier1> <url1>
# <identifier2> <url2>
# ...

OPTIONS=$(awk '{print $1}' ~/.cache/bookmarks.txt)

# echo to dmenu
CHOICE=$(printf '%s\n' "$OPTIONS" | sort | dmenu -i -p "Choose wisely:") || exit 0

[ "$CHOICE" = "tipptest" ] && setxkbmap de && dunstify -r 2591 -u normal "KEYBOARD:de" 
URL=$(grep "$CHOICE" ~/.cache/bookmarks.txt | awk '{print $2}') && [ -z "$URL" ] && exit 0 || brave --new-window "$URL" 




