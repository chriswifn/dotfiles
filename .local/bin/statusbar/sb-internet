#!/bin/sh

if grep -xq 'up' /sys/class/net/wl*/operstate 2>/dev/null ; then
  wifiicon="Wi-Fi"
elif grep -xq 'down' /sys/class/net/wl*/operstate 2>/dev/null ; then
  grep -xq '0x1003' /sys/class/net/wl*/flags && wifiicon="down" || wifiicon="n/a"
fi

printf "%s %s %s%s\n" "$wifiicon" "$(sed "s/down/n\/a/;s/up/ETH/" /sys/class/net/enp2*/operstate)" "$(sed "s/.*/vpn/"  /sys/class/net/wg-*/operstate 2>/dev/null)" "$(sed "s/.*/uni/" /sys/class/net/ppp*/operstate 2>/dev/null)"

